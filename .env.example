# ═══════════════════════════════════════════════════════════════
# Oracle Fusion AI Diagnostic Agent — Environment Configuration
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Security (REQUIRED — generate with: openssl rand -base64 32) ─
JWT_SECRET_KEY=CHANGE_ME_MINIMUM_32_CHARS
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_KEY

# ── Oracle Fusion (REQUIRED) ─────────────────────────────────────
ORACLE_FUSION_BASE_URL=https://your-tenant.fa.us2.oraclecloud.com
ORACLE_FUSION_USERNAME=service_account@company.com
ORACLE_FUSION_PASSWORD=CHANGE_ME
ORACLE_FUSION_MFA_ENABLED=false

# ── Gemini AI (REQUIRED) ─────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_CHANGE_ME
GEMINI_MODEL=gemini-2.5-pro

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=fusion
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=fusionagent
DATABASE_URL=postgresql+asyncpg://fusion:CHANGE_ME@localhost:5432/fusionagent

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ──────────────────────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ── Browser ───────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
BROWSER_POOL_MAX_SIZE=5

# ── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
